import { describe, it, expect, beforeEach, vi } from 'vitest';
import * as service from '../myService';
import * as dependency from '../dependency';

// Mock dependencies
vi.mock('../dependency', () => ({
  fetchData: vi.fn(),
  fetchDataById: vi.fn(),
}));

describe('myService', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe('getData', () => {
    it('should return data on success', async () => {
      const mockData = { id: '1', name: 'Test', value: 100 };
      vi.mocked(dependency.fetchData).mockResolvedValue(mockData);

      const result = await service.getData('user-123');

      expect(result.success).toBe(true);
      expect(result.data).toEqual(mockData);
    });

    it('should handle errors', async () => {
      vi.mocked(dependency.fetchData).mockRejectedValue(new Error('API Error'));

      const result = await service.getData('user-123');

      expect(result.success).toBe(false);
      expect(result.error).toBe('API Error');
    });

    it('should handle empty results', async () => {
      vi.mocked(dependency.fetchData).mockResolvedValue(null);

      const result = await service.getData('user-123');

      expect(result.success).toBe(false);
      expect(result.error).toContain('not found');
    });
  });

  describe('getDataById', () => {
    it('should return data by ID', async () => {
      const mockData = { id: '1', name: 'Test' };
      vi.mocked(dependency.fetchDataById).mockResolvedValue(mockData);

      const result = await service.getDataById('1');

      expect(result).toEqual(mockData);
      expect(dependency.fetchDataById).toHaveBeenCalledWith('1');
    });
  });
});

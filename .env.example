# LLM Flux Gateway Environment Variables

# ============================================
# Required
# ============================================

# Gemini API Key (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Optional
# ============================================

# Database Path (default: ./data/gateway.db)
DATABASE_PATH=./data/gateway.db

# Maximum number of logs to keep (default: 5000)
# Favorited logs are exempt from this limit
MAX_LOGS_COUNT=5000

# CORS Allowed Origins (comma-separated, default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# ============================================
# AI Component Analysis
# ============================================

# LLM API Base URL (OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.openai.com/v1

# LLM API Key
LLM_API_KEY=your_llm_api_key_here

# LLM Model (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# ============================================
# Admin Authentication
# ============================================

# Admin username for accessing the management interface
ADMIN_USERNAME=admin

# Admin password for accessing the management interface
# IMPORTANT: Change this in production!
ADMIN_PASSWORD=changeme

# Maximum failed login attempts before IP blocking (default: 5)
MAX_LOGIN_ATTEMPTS=5

# Duration in minutes to block IP after max attempts (default: 5)
LOGIN_BLOCK_MINUTES=5

# Session duration in days (default: 7)
SESSION_EXPIRE_DAYS=7

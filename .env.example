# LLM Flux Gateway Environment Variables

# ============================================
# Required
# ============================================

# Gemini API Key (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Optional
# ============================================

# Database Path (default: ./data/gateway.db)
DATABASE_PATH=./data/gateway.db

# Maximum number of logs to keep (default: 5000)
# Favorited logs are exempt from this limit
MAX_LOGS_COUNT=5000

# CORS Allowed Origins (comma-separated, default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

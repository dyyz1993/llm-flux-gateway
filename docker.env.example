# LLM Flux Gateway Docker Environment Variables

# Gemini API Key (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# API Base URL (Frontend will use this to call Backend)
# Set to empty "" to automatically use current domain/port (Recommended for same-host deployment)
VITE_API_BASE_URL=

# Database Path (inside container should be /app/data/gateway.db)
DATABASE_PATH=/app/data/gateway.db

# Maximum number of logs to keep
MAX_LOGS_COUNT=5000

# CORS Allowed Origins
CORS_ORIGINS=http://localhost:3000
